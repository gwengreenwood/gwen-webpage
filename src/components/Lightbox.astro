---
// Full-screen image viewer. Opens when any image inside `.masonry` is clicked.
// No dependencies; progressive enhancement (grid still works without JS).
---

<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lightbox-close" type="button" aria-label="Close viewer">✕</button>
  <button class="lightbox-nav lightbox-prev" type="button" aria-label="Previous image">‹</button>
  <figure class="lightbox-stage">
    <img class="lightbox-img" src="" alt="" />
    <figcaption class="lightbox-caption" hidden></figcaption>
  </figure>
  <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image">›</button>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3.5rem);
    background: rgba(18, 15, 13, 0.94);
    backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .lightbox.open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-stage {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
    max-width: 100%;
    max-height: 100%;
  }

  .lightbox-img {
    display: block;
    max-width: min(1400px, 100%);
    max-height: 84vh;
    width: auto;
    height: auto;
    object-fit: contain;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
    transform: scale(0.98);
    transition: transform 0.25s ease;
  }

  .lightbox.open .lightbox-img {
    transform: scale(1);
  }

  .lightbox-caption {
    color: rgba(246, 242, 236, 0.82);
    font-family: "Fraunces", Georgia, serif;
    font-style: italic;
    font-size: 0.95rem;
    text-align: center;
  }

  .lightbox-close,
  .lightbox-nav {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(246, 242, 236, 0.1);
    border: 1px solid rgba(246, 242, 236, 0.22);
    color: #f6f2ec;
    cursor: pointer;
    border-radius: 999px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .lightbox-close:hover,
  .lightbox-nav:hover,
  .lightbox-close:focus-visible,
  .lightbox-nav:focus-visible {
    background: rgba(246, 242, 236, 0.2);
    border-color: rgba(246, 242, 236, 0.5);
  }

  .lightbox-close {
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1.1rem;
  }

  .lightbox-nav {
    top: 50%;
    transform: translateY(-50%);
    width: 3.25rem;
    height: 3.25rem;
    font-size: 2rem;
    line-height: 1;
  }

  .lightbox-prev {
    left: clamp(0.75rem, 3vw, 2rem);
  }

  .lightbox-next {
    right: clamp(0.75rem, 3vw, 2rem);
  }

  @media (max-width: 560px) {
    .lightbox-nav {
      width: 2.6rem;
      height: 2.6rem;
      font-size: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .lightbox-img {
      transition: none;
    }
  }
</style>

<script>
  const lb = document.getElementById("lightbox");

  if (lb) {
    const imgEl = lb.querySelector(".lightbox-img") as HTMLImageElement;
    const capEl = lb.querySelector(".lightbox-caption") as HTMLElement;
    const btnPrev = lb.querySelector(".lightbox-prev") as HTMLButtonElement;
    const btnNext = lb.querySelector(".lightbox-next") as HTMLButtonElement;
    const btnClose = lb.querySelector(".lightbox-close") as HTMLButtonElement;
    const triggers = Array.from(
      document.querySelectorAll<HTMLImageElement>(".masonry img"),
    );

    let index = 0;

    const render = () => {
      const t = triggers[index];
      if (!t) return;
      imgEl.src = t.currentSrc || t.src;
      imgEl.alt = t.alt || "";
      const caption = t.alt?.trim();
      capEl.textContent = caption || "";
      capEl.hidden = !caption;
      const multiple = triggers.length > 1;
      btnPrev.hidden = !multiple;
      btnNext.hidden = !multiple;
    };

    const open = (i: number) => {
      index = i;
      render();
      lb.classList.add("open");
      lb.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      btnClose.focus();
    };

    const close = () => {
      lb.classList.remove("open");
      lb.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };

    const step = (delta: number) => {
      index = (index + delta + triggers.length) % triggers.length;
      render();
    };

    triggers.forEach((t, i) => {
      t.style.cursor = "zoom-in";
      t.addEventListener("click", () => open(i));
    });

    btnClose.addEventListener("click", close);
    btnPrev.addEventListener("click", (e) => {
      e.stopPropagation();
      step(-1);
    });
    btnNext.addEventListener("click", (e) => {
      e.stopPropagation();
      step(1);
    });

    // Click the backdrop (not the image or buttons) to close.
    lb.addEventListener("click", (e) => {
      if (e.target === lb || e.target === lb.querySelector(".lightbox-stage")) {
        close();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (!lb.classList.contains("open")) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") step(-1);
      else if (e.key === "ArrowRight") step(1);
    });
  }
</script>
