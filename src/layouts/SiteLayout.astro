---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
};

const {
  title = "Gwen | Poems",
  description = "A polished home for Gwen's poems, images, and music.",
  bodyClass = "",
} = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/poems/", label: "Poems" },
  { href: "/gallery/", label: "Gallery" },
  { href: "/admin/", label: "Admin" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09120f" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Gwen home">Gwen</a>
      <nav class="site-nav" aria-label="Main navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Gwen</p>
      <p>Poems, images, and music kept in simple files.</p>
    </footer>
  </body>
</html>
