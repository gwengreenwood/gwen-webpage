---
import "../styles/global.css";
import { sitePath } from "../lib/paths";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
};

const {
  title = "Gwenevere Ivy Greenwood",
  description = "A personal home for Gwenevere Ivy Greenwood's poetry, short fiction, and artwork.",
  bodyClass = "",
} = Astro.props;

const navItems = [
  { href: "/poems/", label: "Poetry" },
  { href: "/short-stories/", label: "Short Stories" },
  { href: "/artwork/", label: "Artwork" },
  { href: "/photography/", label: "Photography" },
];

const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

function isActive(href: string): boolean {
  return currentPath === href || currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f2ec" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={sitePath("/")} aria-label="Gwenevere Ivy Greenwood home">
        Gwenevere Ivy Greenwood
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a
              href={sitePath(item.href)}
              class:list={{ active: isActive(item.href) }}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>Gwenevere Ivy Greenwood</p>
      <p>Poetry, short fiction, and artwork.</p>
    </footer>
  </body>
</html>
