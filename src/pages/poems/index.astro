---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories, getCategoryPath, getPoemPath, poems } from "../../lib/poems";
import { mediaPath, sitePath } from "../../lib/paths";
---

<SiteLayout title="Poems | Gwen" description="Browse Gwen's poems.">
  <section class="page-hero">
    <h1>Poems</h1>
    <p>
      A growing archive organized into editable categories. Choose a category to
      read the poems inside it.
    </p>
  </section>
  <section class="section dark">
    <div class="section-header">
      <h2>Categories</h2>
      <a class="text-link" href={sitePath("/admin/")}>Edit categories →</a>
    </div>
    <div class="category-grid" aria-label="Poem categories">
      {
        categories.map((category) => (
          <a class="category-card" href={getCategoryPath(category)}>
            {category.image && <img src={mediaPath(category.image)} alt="" loading="lazy" />}
            <div>
              <h3>{category.title}</h3>
              <p>{category.description}</p>
              <p class="meta">
                {category.poems.length} {category.poems.length === 1 ? "poem" : "poems"}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
  <section class="poems-list" aria-label="Recent poem list">
    {
      poems.map((poem) => (
        <a class="poem-card vertical" href={getPoemPath(poem)}>
          <img src={mediaPath(poem.image)} alt="" loading="lazy" />
          <div class="poem-card-body">
            <h3>{poem.title}</h3>
            <p>{poem.summary}</p>
            <p class="meta">{poem.dateLabel}</p>
            {poem.tags && (
              <div class="tags" aria-label="Tags">
                {poem.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))
    }
  </section>
</SiteLayout>
