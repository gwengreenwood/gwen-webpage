---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { categories, getCategoryPath } from "../../lib/poems";

const collections = categories.filter((category) => category.poems.length > 0);
const pad = (index: number) => String(index + 1).padStart(2, "0");
---

<SiteLayout
  title="Poetry | Gwenevere Ivy Greenwood"
  description="Poems and collections by Gwenevere Ivy Greenwood."
>
  <section class="page-hero">
    <h1>Poetry</h1>
    <p>
      Each collection gathers poems around a shared feeling. Open one to begin
      reading.
    </p>
  </section>

  <section class="index" aria-label="Collections">
    <ol class="collections">
      {
        collections.map((category, index) => (
          <li>
            <a href={getCategoryPath(category)}>
              <span class="num">{pad(index)}</span>
              <span class="title">{category.title}</span>
              <span class="go">
                {category.poems.length} {category.poems.length === 1 ? "poem" : "poems"} →
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</SiteLayout>
