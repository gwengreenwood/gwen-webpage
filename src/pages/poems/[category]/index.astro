---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { categories, getPoemPath, getPoemsByCategory } from "../../../lib/poems";
import { sitePath } from "../../../lib/paths";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryPoems = getPoemsByCategory(category.slug);
---

<SiteLayout
  title={`${category.title} | Gwenevere Ivy Greenwood`}
  description={`${category.title} poems by Gwenevere Ivy Greenwood.`}
>
  <div class="category-page">
    <section class="page-hero category-hero">
      <p class="eyebrow">
        <a href={sitePath("/poems/")}>Poetry</a> · Collection
      </p>
      <h1>{category.title}</h1>
    </section>

    <section class="section category-poems-section" aria-label={`${category.title} poems`}>
      <ol class="poem-list">
        {
          categoryPoems.map((poem) => (
            <li>
              <a href={getPoemPath(poem)}>{poem.title}</a>
            </li>
          ))
        }
      </ol>
    </section>
  </div>
</SiteLayout>
