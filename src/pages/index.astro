---
import SiteLayout from "../layouts/SiteLayout.astro";
import { featuredPoems, getPoemPath, poems } from "../lib/poems";

const galleryImages = poems.slice(0, 4);
---

<SiteLayout>
  <section class="hero">
    <div class="hero-inner">
      <h1>Poems for the in-between light.</h1>
      <p>
        Writing down the things that stay with us quietly, persistently, and
        faithfully until they become song.
      </p>
      <div class="cta-row">
        <a class="button" href="/poems/">Browse poems <span aria-hidden="true">→</span></a>
        <a class="button secondary" href="/admin/">Admin <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section dark">
    <div class="section-header">
      <h2>Recent Poems</h2>
      <a class="text-link" href="/poems/">View all poems →</a>
    </div>
    <div class="poem-grid">
      {
        featuredPoems.map((poem) => (
          <a class="poem-card" href={getPoemPath(poem)}>
            <img src={poem.image} alt="" loading="lazy" />
            <div>
              <h3>{poem.title}</h3>
              <p>{poem.summary}</p>
              <p class="meta">{poem.dateLabel}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section dark">
    <div class="section-header">
      <h2>Gallery</h2>
      <a class="text-link" href="/gallery/">View gallery →</a>
    </div>
    <div class="gallery-strip">
      {
        galleryImages.map((poem) => (
          <a href={getPoemPath(poem)} aria-label={`Open ${poem.title}`}>
            <img src={poem.image} alt="" loading="lazy" />
          </a>
        ))
      }
    </div>
  </section>

  <section class="section paper quote-band">
    <blockquote>
      “I write to make sense of the soft things, the ones that blur, the ones
      that last.”
    </blockquote>
    <div>
      <p>
        Each poem page is built for a full reading mood: image, scrollable text,
        and music when a track is attached.
      </p>
      <a class="button" href="/admin/">Add new work <span aria-hidden="true">→</span></a>
    </div>
  </section>
</SiteLayout>
