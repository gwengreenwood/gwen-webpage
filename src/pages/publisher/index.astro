---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { sitePath } from "../../lib/paths";

const template = `---
title: "Your Poem Title"
date: "2026-05-09"
summary: "One short sentence that describes the feeling of the poem."
category: "weather-and-water"
image: "/media/images/your-image.jpg"
music: "/media/music/your-song.mp3"
tags:
  - memory
  - evening
featured: true
draft: false
---

Write your poem here.

Use a blank line between stanzas.

To force a single line break,
add two spaces at the end of the previous line.`;
---

<SiteLayout title="Publisher | Gwen" description="Add poems, images, and music.">
  <section class="page-hero">
    <h1>Publisher</h1>
    <p>
      The admin screen lives at <code>/admin/</code>. It gives you a website
      login and form editor for poems, images, and music.
    </p>
  </section>

  <section class="publisher-layout">
    <div class="publisher-section">
      <h2>Website editor</h2>
      <p>
        Open the admin page from your published website. You will see a login
        screen, then a form-based editor for adding and changing poems.
      </p>
      <p>
        <a class="button" href={sitePath("/admin/")}>Open admin <span aria-hidden="true">→</span></a>
      </p>
    </div>

    <div class="publisher-section">
      <h2>File folders</h2>
      <ul>
        <li><code>src/content/categories/</code> holds editable category files.</li>
        <li><code>src/content/poems/</code> holds poem files.</li>
        <li><code>public/media/images/</code> holds poem images.</li>
        <li><code>public/media/music/</code> holds music files.</li>
      </ul>
    </div>

    <div class="publisher-section">
      <h2>New poem template</h2>
      <div class="template-box">
        <pre>{template}</pre>
      </div>
    </div>

    <div class="publisher-section">
      <h2>Publish flow</h2>
      <ol>
        <li>Log in at <code>/admin/</code>.</li>
        <li>Edit category names in <code>Poem Categories</code>.</li>
        <li>Open the <code>Poems</code> section.</li>
        <li>Add or edit the poem, image, and music.</li>
        <li>Click publish. GitHub Pages will rebuild the public site.</li>
      </ol>
    </div>
  </section>
</SiteLayout>
